# ============================================================================
# Rivus API — exemplo de .env
#
# Em produção (provisionado pela plataforma Artificialis), o arquivo .env é
# gerado automaticamente pelo serviceRecipes.js#buildClientStack — você não
# precisa preencher esses valores manualmente. Este arquivo serve só pra dev
# local + documentação.
# ============================================================================

# DB do tenant (no compose: postgresql://<slug>:<senha>@postgres:5432/<slug>_rivus)
DATABASE_URL=postgresql://rivus:senha@localhost:5432/rivus_rivus

# JWT secret usado pra assinar sessões admin. MIN 32 chars. Preservado entre
# redeploys via existingSecrets.rivusJwtSecret — mudar invalida sessões.
RIVUS_JWT_SECRET=change-me-to-at-least-32-random-bytes-base64url

# Token usado pelo platform backend pra chamar /admin/seed na primeira
# instalação. Preservado entre redeploys via existingSecrets.rivusSeedToken.
RIVUS_SEED_TOKEN=change-me-to-at-least-32-random-bytes-base64url

# Porta interna do container (host:porta é mapeado pelo compose recipe)
PORT=3001

# Node env (production em prod, development local)
NODE_ENV=development

# Origens permitidas pelo CORS. Em prod, plataforma seta automaticamente
# pro custom_domain do tenant + www.
RIVUS_CORS_ORIGINS=http://localhost:8080,https://rivus.trading,https://www.rivus.trading

# Cookie httpOnly da sessão admin. Customizável pra evitar conflito se
# tenant rodar múltiplos services no mesmo domínio.
COOKIE_NAME=rivus_admin_session

# TTL do JWT — formato ms ou sufixo "30d" / "12h"
TOKEN_TTL=30d

# Versão da API exposta no /health — buildtime via Dockerfile ARG
RIVUS_API_VERSION=dev

# Trust proxy — em prod o Caddy é o reverse proxy, então 'loopback' funciona.
# Se mudar pra cluster setup, ajustar.
TRUST_PROXY=loopback

# Timezone da aplicação (logs, timestamps default)
TZ=America/Sao_Paulo
